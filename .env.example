JWT_SECRET=routergui-dev-secret-change-in-production
DATABASE_URL=file:./prisma/dev.db
PORT=3001
NODE_ENV=development

# Public base URL the ACS (e.g. IXC) uses to reach this CPE for TR-069
# Connection Requests. REQUIRED when the ACS is remote — IXC blocks localhost
# and private IPs (SSRF). Point it at a tunnel or public host. Examples:
#   PUBLIC_BASE_URL=https://your-name.trycloudflare.com   (Cloudflare Tunnel)
#   PUBLIC_BASE_URL=https://abcd1234.ngrok-free.app        (ngrok)
#   PUBLIC_BASE_URL=http://203.0.113.10:3001               (VPS / port-forward)
# Leave unset only for local ACS testing (defaults to http://localhost:3001).
# PUBLIC_BASE_URL=

# Path of the public Connection Request endpoint (no JWT).
# CONNECTION_REQUEST_PATH=/cwmp/connection-request

# Optional HTTP Digest credentials the ACS must use to trigger a Connection
# Request. Leave empty to accept unauthenticated requests (test/simulator).
# CONNECTION_REQUEST_USERNAME=
# CONNECTION_REQUEST_PASSWORD=
