generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  passwordHash       String
  role               String   @default("USER")
  enabled            Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model VirtualDevice {
  id              String   @id @default(uuid())
  manufacturer    String   @default("AeroBerry")
  modelName       String   @default("RGX-5000")
  softwareVersion String   @default("1.0.0")
  hardwareVersion String   @default("RGX-HW-A1")
  serialNumber    String   @unique
  osName          String   @default("AeroBerry OS")
  capabilitiesJson String  @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parameters    Tr098Parameter[]
  wanConfig     WanConfig?
  wanInterfaces WanInterface[]
  lanConfig     LanConfig?
  wlanConfigs   WlanConfig[]
  firewallRules FirewallRule[]
  portForwards  PortForward[]
  dmzConfig     DmzConfig?
  logEntries    LogEntry[]
  cwmpSession   CwmpSession?
  metrics           SimulatedMetrics?
  snapshots         DeviceSnapshot[]
  connectedHosts    ConnectedHost[]
  wifiNeighbors     WifiNeighbor[]
  bandSteering      BandSteeringConfig?
  speedTestResults  SpeedTestResult[]
  ipv6Config        Ipv6Config?
  guestWlan         GuestWlanConfig?
  wirelessInterfaces WirelessInterface[]
  dhcpReservations  DhcpReservation[]
  staticRoutes      StaticRoute[]
  upnpConfig        UpnpConfig?
  qosRules          QosRule[]
  vpnConfig         VpnConfig?
  firmwareInfo      FirmwareInfo?
  ntpConfig             NtpConfig?
  webManagementConfig   WebManagementConfig?
  opticalInfo           OpticalInfo?
  voipLines         VoipLine[]
  securitySettings  SecuritySettings?
}

model Tr098Parameter {
  id           String   @id @default(uuid())
  deviceId     String
  path         String
  value        String   @default("")
  type         String   @default("string")
  writable     Boolean  @default(false)
  notification Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, path])
  @@index([deviceId])
}

model WanConfig {
  id               String   @id @default(uuid())
  deviceId         String   @unique
  connectionType   String   @default("DHCP")
  ipAddress        String   @default("192.0.2.10")
  subnetMask       String   @default("255.255.255.0")
  gateway          String   @default("192.0.2.1")
  dnsPrimary       String   @default("8.8.8.8")
  dnsSecondary     String   @default("8.8.4.4")
  dnsAuto          Boolean  @default(true)
  mtu              Int      @default(1500)
  pppoeUsername    String?
  pppoePassword    String?
  pppoeServiceName String   @default("")
  pppoeAcName      String   @default("")
  pppoeMtu         Int      @default(1492)
  pppoeConnected   Boolean  @default(false)
  pppoeAuthStatus  String   @default("authenticated")
  vlanEnabled      Boolean  @default(false)
  vlanId           Int      @default(0)
  vlanPriority     Int      @default(0)
  natEnabled       Boolean  @default(true)
  natType          String   @default("NAT")
  enabled          Boolean  @default(true)
  status           String   @default("connected")
  connectedSince   DateTime?
  lastReconnect    DateTime?
  downloadBandwidthMbps Int @default(500)
  uploadBandwidthMbps   Int @default(250)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model WanInterface {
  id             String   @id @default(uuid())
  deviceId       String
  name           String
  serviceType    String   @default("INTERNET")
  connectionType String   @default("DHCP")
  enabled        Boolean  @default(true)
  ipAddress      String   @default("0.0.0.0")
  subnetMask     String   @default("255.255.255.0")
  gateway        String   @default("0.0.0.0")
  dnsPrimary     String   @default("8.8.8.8")
  dnsSecondary   String   @default("8.8.4.4")
  mtu            Int      @default(1500)
  pppoeUsername  String?
  pppoePassword  String?
  vlanEnabled    Boolean  @default(false)
  vlanId         Int      @default(0)
  natEnabled     Boolean  @default(true)
  status         String   @default("connected")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model LanConfig {
  id             String  @id @default(uuid())
  deviceId       String  @unique
  ipAddress      String  @default("192.168.1.1")
  subnetMask     String  @default("255.255.255.0")
  dhcpEnabled    Boolean @default(true)
  dhcpRangeStart String  @default("192.168.1.100")
  dhcpRangeEnd   String  @default("192.168.1.200")
  dnsPrimary     String  @default("8.8.8.8")
  dnsSecondary   String  @default("8.8.4.4")
  dnsAuto        Boolean @default(true)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model WlanConfig {
  id           String  @id @default(uuid())
  deviceId     String
  band         String
  enabled      Boolean @default(true)
  ssid         String
  channel      Int
  channelWidth String  @default("20MHz")
  security     String  @default("WPA2")
  password     String  @default("")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, band])
}

model FirewallRule {
  id         String  @id @default(uuid())
  deviceId   String
  name       String
  direction  String
  protocol   String
  sourceIp   String  @default("any")
  destIp     String  @default("any")
  sourcePort String  @default("any")
  destPort   String  @default("any")
  action     String
  enabled    Boolean @default(true)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model PortForward {
  id           String  @id @default(uuid())
  deviceId     String
  name         String
  externalPort Int
  internalIp   String
  internalPort Int
  protocol     String  @default("TCP")
  enabled      Boolean @default(true)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model DmzConfig {
  id       String  @id @default(uuid())
  deviceId String  @unique
  enabled  Boolean @default(false)
  hostIp   String  @default("")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model LogEntry {
  id        String   @id @default(uuid())
  deviceId  String
  type      String
  message   String
  details   String?
  createdAt DateTime @default(now())

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
}

model CwmpSession {
  id                     String    @id @default(uuid())
  deviceId               String    @unique
  acsUrl                 String    @default("")
  acsUsername            String    @default("")
  acsPassword            String    @default("")
  periodicInformEnabled  Boolean   @default(true)
  periodicInformInterval Int       @default(300)
  sessionState           String    @default("idle")
  lastInform             DateTime?
  lastEventCodes         String    @default("[]")
  pendingEvents          String    @default("[]")
  bootstrapSent          Boolean   @default(false)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model SimulatedMetrics {
  id          String   @id @default(uuid())
  deviceId    String   @unique
  cpuUsage    Float    @default(25.0)
  memoryUsage Float    @default(55.0)
  uptime      Int      @default(0)
  bootTime    DateTime @default(now())

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model DeviceSnapshot {
  id        String   @id @default(uuid())
  deviceId  String
  label     String
  data      String
  createdAt DateTime @default(now())

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model ConnectedHost {
  id          String   @id @default(uuid())
  deviceId    String
  macAddress  String
  ipAddress   String
  hostname    String
  interface   String   @default("lan")
  band        String?
  rssi        Int?
  leaseExpiry DateTime?
  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model WifiNeighbor {
  id        String   @id @default(uuid())
  deviceId  String
  bssid     String
  ssid      String
  channel   Int
  rssi      Int
  security  String   @default("WPA2")
  band      String
  scannedAt DateTime @default(now())

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, scannedAt])
}

model BandSteeringConfig {
  id             String  @id @default(uuid())
  deviceId       String  @unique
  enabled           Boolean @default(true)
  rssiThreshold24   Int     @default(-70)
  rssiThreshold5    Int     @default(-65)
  prefer5G          Boolean @default(true)
  clientSteering    Boolean @default(true)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model SpeedTestResult {
  id           String   @id @default(uuid())
  deviceId     String
  downloadMbps Float
  uploadMbps   Float
  latencyMs    Float
  jitterMs     Float    @default(2)
  server       String   @default("AeroBerry Speed Server")
  testedAt     DateTime @default(now())

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, testedAt])
}

model Ipv6Config {
  id               String  @id @default(uuid())
  deviceId         String  @unique
  wanEnabled       Boolean @default(false)
  wanMode          String  @default("auto")
  lanEnabled       Boolean @default(true)
  lanPrefix        String  @default("fd00::/64")
  dhcpv6Enabled    Boolean @default(true)
  slaacEnabled     Boolean @default(true)
  prefixDelegation Boolean @default(true)
  wanAddress       String  @default("2001:db8:1::2")
  wanGateway       String  @default("2001:db8:1::1")
  wanDns           String  @default("2001:db8:1::53")
  prefixLength     Int     @default(64)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model GuestWlanConfig {
  id        String  @id @default(uuid())
  deviceId  String  @unique
  enabled   Boolean @default(false)
  ssid      String  @default("RGX-Guest")
  password  String  @default("guest2024")
  security  String  @default("WPA2")
  isolation Boolean @default(true)
  band      String  @default("2.4")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model WirelessInterface {
  id                   String   @id @default(uuid())
  deviceId             String
  interfaceId          String
  name                 String
  interfaceType        String
  band                 String
  enabled              Boolean  @default(true)
  hidden               Boolean  @default(false)
  ssid                 String
  channel              Int
  channelWidth         String   @default("20MHz")
  security             String   @default("wpa2-psk-aes")
  password             String   @default("")
  isolated             Boolean  @default(false)
  vlanId               Int?
  bandwidthLimitMbps   Int?
  captivePortal        Boolean  @default(false)
  scheduleEnabled      Boolean  @default(false)
  scheduleStart        String?
  scheduleEnd          String?
  ipv4Enabled          Boolean  @default(true)
  ipv6Enabled          Boolean  @default(true)
  backhaulMode         String?
  linkQuality          Int?
  linkStatus           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, interfaceId])
  @@index([deviceId, interfaceType])
}

model DhcpReservation {
  id         String @id @default(uuid())
  deviceId   String
  macAddress String
  ipAddress  String
  hostname   String @default("")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, macAddress])
  @@index([deviceId])
}

model StaticRoute {
  id          String  @id @default(uuid())
  deviceId    String
  destination String
  subnetMask  String
  gateway     String
  interface   String  @default("wan")
  enabled     Boolean @default(true)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model UpnpConfig {
  id       String  @id @default(uuid())
  deviceId String  @unique
  enabled  Boolean @default(true)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model QosRule {
  id       String  @id @default(uuid())
  deviceId String
  name     String
  priority Int     @default(5)
  protocol String  @default("ANY")
  srcPort  String  @default("any")
  destPort String  @default("any")
  dscp     Int     @default(0)
  enabled  Boolean @default(true)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model VpnConfig {
  id       String  @id @default(uuid())
  deviceId String  @unique
  type     String  @default("OpenVPN")
  server   String  @default("")
  username String  @default("")
  password String  @default("")
  enabled  Boolean @default(false)

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model FirmwareInfo {
  id             String    @id @default(uuid())
  deviceId       String    @unique
  currentVersion String    @default("1.0.0")
  pendingVersion String?
  lastUpgrade    DateTime?
  upgradeStatus  String    @default("idle")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model NtpConfig {
  id              String @id @default(uuid())
  deviceId        String @unique
  server          String @default("pool.ntp.org")
  serverSecondary String @default("time.google.com")
  timezone        String @default("UTC")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model WebManagementConfig {
  id            String  @id @default(uuid())
  deviceId      String  @unique
  enabled       Boolean @default(true)
  remoteAccess  Boolean @default(false)
  remotePort    Int     @default(8080)
  localPort     Int     @default(80)
  httpsEnabled  Boolean @default(false)
  httpsPort     Int     @default(443)
  adminUsername String  @default("admin")
  adminPassword String  @default("")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model OpticalInfo {
  id          String @id @default(uuid())
  deviceId    String @unique
  rxPowerDbm  Float  @default(-18.5)
  txPowerDbm  Float  @default(2.1)
  temperature Float  @default(42.0)
  ponStatus   String @default("registered")
  oltId       String @default("OLT-001")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model SecuritySettings {
  id                       String   @id @default(uuid())
  deviceId                 String   @unique
  securityProfile          String   @default("isp-standard")
  forcePasswordChange      Boolean  @default(false)
  factorySsid              String   @default("")
  factoryWifiPassword      String   @default("")
  passwordHashAlgorithm    String   @default("bcrypt")
  credentialEncryptionType String   @default("aes-256")
  backupEncryptionType     String   @default("aes-256")
  legacyCompatibility      Boolean  @default(false)
  certType                 String   @default("rsa-2048")
  certAlgorithm            String   @default("RSA")
  certBits                 Int      @default(2048)
  certIssuer               String   @default("AeroBerry CA")
  certSubject              String   @default("CN=AeroBerry RGX-5000")
  certSerial               String   @default("")
  certFingerprint          String   @default("")
  certValidFrom            DateTime @default(now())
  certValidTo              DateTime
  certPublicKey            String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model VoipLine {
  id       String @id @default(uuid())
  deviceId String
  lineId   Int
  number   String @default("")
  status   String @default("idle")

  device VirtualDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, lineId])
}
